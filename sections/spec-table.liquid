{%- liquid
  assign s = section.settings
-%}
<style>
  #shopify-section-{{ section.id }} .cmn-spec {
    background-color: {{ s.background_color }};
    padding-block: {{ s.padding_top }}px {{ s.padding_bottom }}px;
  }
  #shopify-section-{{ section.id }} .cmn-spec__wrap {
    max-width: {{ s.table_max_width }}px;
    margin-inline: auto;
    padding-inline: 24px;
  }
  #shopify-section-{{ section.id }} .cmn-spec__heading { text-align: center; margin: 0 0 2rem; color: {{ s.heading_color }}; }
  #shopify-section-{{ section.id }} .cmn-spec__table {
    width: 100%;
    border-collapse: collapse;
    font-family: var(--font-body--family);
  }
  #shopify-section-{{ section.id }} .cmn-spec__table th,
  #shopify-section-{{ section.id }} .cmn-spec__table td {
    border: 1px solid {{ s.border_color }};
    padding: 0.7rem 1rem;
    text-align: left;
    font-weight: 400;
    font-size: 1.05rem;
    line-height: 1.4;
    color: {{ s.text_color }};
    vertical-align: top;
  }
  #shopify-section-{{ section.id }} .cmn-spec__table th { width: 55%; }
  #shopify-section-{{ section.id }} .cmn-spec__link { text-align: center; margin: 2rem 0 0; font-size: 1.05rem; }
  #shopify-section-{{ section.id }} .cmn-spec__link a { color: {{ s.link_color }}; text-decoration: underline; font-weight: 700; }
</style>

<div class="cmn-spec">
  <div class="cmn-spec__wrap">
    {%- if s.heading != blank -%}
      <h2 class="cmn-spec__heading">{{ s.heading }}</h2>
    {%- endif -%}
    {%- if section.blocks.size > 0 -%}
      <table class="cmn-spec__table">
        {%- for block in section.blocks -%}
          <tr {{ block.shopify_attributes }}>
            <th>{{ block.settings.label }}</th>
            <td>{{ block.settings.value }}</td>
          </tr>
        {%- endfor -%}
      </table>
    {%- endif -%}
    {%- if s.link_label != blank -%}
      <p class="cmn-spec__link"><a {% if s.link_url != blank %}href="{{ s.link_url }}"{% endif %}>{{ s.link_label }}</a></p>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Spec table",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Caracteristici tehnice" },
    { "type": "range", "id": "table_max_width", "label": "Table max width", "min": 360, "max": 900, "step": 20, "unit": "px", "default": 560 },
    { "type": "header", "content": "Footer link" },
    { "type": "text", "id": "link_label", "label": "Link label" },
    { "type": "url", "id": "link_url", "label": "Link URL" },
    { "type": "header", "content": "Appearance" },
    { "type": "color", "id": "background_color", "label": "Background", "default": "#ffffff" },
    { "type": "color", "id": "heading_color", "label": "Heading color", "default": "#606452" },
    { "type": "color", "id": "text_color", "label": "Table text color", "default": "#606452" },
    { "type": "color", "id": "border_color", "label": "Border color", "default": "#d9d5c2" },
    { "type": "color", "id": "link_color", "label": "Link color", "default": "#b1a45a" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 48 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 64 }
  ],
  "blocks": [
    {
      "type": "row",
      "name": "Row",
      "settings": [
        { "type": "text", "id": "label", "label": "Label" },
        { "type": "text", "id": "value", "label": "Value" }
      ]
    }
  ],
  "presets": [{ "name": "Spec table" }]
}
{% endschema %}
