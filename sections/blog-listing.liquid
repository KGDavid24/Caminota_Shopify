{%- liquid
  assign s = section.settings
-%}
<style>
  #shopify-section-{{ section.id }} .cmn-blog {
    background-color: {{ s.background_color }};
    padding-block: {{ s.padding_top }}px {{ s.padding_bottom }}px;
  }
  #shopify-section-{{ section.id }} .cmn-blog__wrap {
    max-width: {{ s.max_width }}px;
    margin-inline: auto;
    padding-inline: 24px;
  }
  #shopify-section-{{ section.id }} .cmn-blog__heading { text-align: center; margin: 0 0 3rem; color: {{ s.heading_color }}; }
  #shopify-section-{{ section.id }} .cmn-blog__grid {
    display: grid;
    grid-template-columns: repeat({{ s.columns }}, 1fr);
    column-gap: {{ s.column_gap }}px;
    row-gap: {{ s.row_gap }}px;
  }
  #shopify-section-{{ section.id }} .cmn-blog__card { display: flex; flex-direction: column; }
  #shopify-section-{{ section.id }} .cmn-blog__media { display: block; overflow: hidden; border-radius: {{ s.image_radius }}px; }
  #shopify-section-{{ section.id }} .cmn-blog__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    aspect-ratio: {{ s.image_ratio }};
    transition: transform 0.4s ease;
  }
  #shopify-section-{{ section.id }} .cmn-blog__media:hover img { transform: scale(1.03); }
  #shopify-section-{{ section.id }} .cmn-blog__date { margin: 1.25rem 0 0.5rem; font-size: 0.95rem; color: {{ s.meta_color }}; }
  #shopify-section-{{ section.id }} .cmn-blog__title {
    font-family: var(--font-heading--family);
    color: {{ s.heading_color }};
    font-size: 1.7rem;
    line-height: 1.2;
    margin: 0 0 1rem;
  }
  #shopify-section-{{ section.id }} .cmn-blog__title a { color: inherit; text-decoration: none; }
  #shopify-section-{{ section.id }} .cmn-blog__title a:hover { text-decoration: underline; }
  #shopify-section-{{ section.id }} .cmn-blog__excerpt { font-size: 1.05rem; line-height: 1.7; color: {{ s.text_color }}; margin: 0 0 1.25rem; }
  #shopify-section-{{ section.id }} .cmn-blog__more { margin-top: auto; }
  #shopify-section-{{ section.id }} .cmn-blog__more a { color: {{ s.link_color }}; text-decoration: underline; font-weight: 600; }
  #shopify-section-{{ section.id }} .cmn-blog__pagination { margin-top: 3.5rem; text-align: center; display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap; }
  #shopify-section-{{ section.id }} .cmn-blog__pagination a,
  #shopify-section-{{ section.id }} .cmn-blog__pagination span {
    color: {{ s.text_color }};
    text-decoration: none;
    padding: 0.4rem 0.8rem;
  }
  #shopify-section-{{ section.id }} .cmn-blog__pagination a:hover { color: {{ s.link_color }}; }
  #shopify-section-{{ section.id }} .cmn-blog__pagination .cmn-blog__page-current { color: {{ s.link_color }}; font-weight: 700; }
  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .cmn-blog__grid { grid-template-columns: 1fr; row-gap: 48px; }
  }
</style>

<div class="cmn-blog">
  <div class="cmn-blog__wrap">
    {%- if s.heading != blank -%}
      <h1 class="cmn-blog__heading">{{ s.heading }}</h1>
    {%- endif -%}

    {%- paginate blog.articles by s.posts_per_page -%}
      <div class="cmn-blog__grid">
        {%- for article in blog.articles -%}
          <article class="cmn-blog__card">
            {%- if article.image != blank -%}
              <a class="cmn-blog__media" href="{{ article.url }}">
                {{ article.image | image_url: width: 1200 | image_tag: loading: 'lazy', sizes: '(min-width: 750px) 50vw, 100vw', widths: '500, 800, 1200' }}
              </a>
            {%- endif -%}
            {%- if s.show_date -%}
              <p class="cmn-blog__date">{{ article.published_at | date: s.date_format }}</p>
            {%- endif -%}
            <h2 class="cmn-blog__title"><a href="{{ article.url }}">{{ article.title }}</a></h2>
            <div class="cmn-blog__excerpt">
              {%- if article.excerpt != blank -%}
                {{ article.excerpt | strip_html }}
              {%- else -%}
                {{ article.content | strip_html | truncatewords: s.excerpt_words }}
              {%- endif -%}
            </div>
            <p class="cmn-blog__more"><a href="{{ article.url }}">{{ s.read_more_label }}</a></p>
          </article>
        {%- endfor -%}
      </div>

      {%- if paginate.pages > 1 -%}
        <div class="cmn-blog__pagination">
          {%- for part in paginate.parts -%}
            {%- if part.is_link -%}
              <a href="{{ part.url }}">{{ part.title }}</a>
            {%- elsif part.title == paginate.current_page -%}
              <span class="cmn-blog__page-current">{{ part.title }}</span>
            {%- else -%}
              <span>{{ part.title }}</span>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}
    {%- endpaginate -%}
  </div>
</div>

{% schema %}
{
  "name": "Blog listing",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading (optional)" },
    { "type": "range", "id": "columns", "label": "Columns", "min": 1, "max": 3, "step": 1, "default": 2 },
    { "type": "range", "id": "posts_per_page", "label": "Posts per page", "min": 2, "max": 24, "step": 1, "default": 10 },
    { "type": "header", "content": "Card" },
    { "type": "select", "id": "image_ratio", "label": "Image ratio", "options": [{ "value": "3 / 2", "label": "Landscape 3:2" }, { "value": "16 / 9", "label": "Wide 16:9" }, { "value": "4 / 3", "label": "Landscape 4:3" }, { "value": "2 / 1", "label": "Wide 2:1" }], "default": "3 / 2" },
    { "type": "range", "id": "image_radius", "label": "Image corner radius", "min": 0, "max": 20, "step": 1, "unit": "px", "default": 0 },
    { "type": "checkbox", "id": "show_date", "label": "Show date", "default": true },
    { "type": "text", "id": "date_format", "label": "Date format", "default": "%d/%m/%Y" },
    { "type": "range", "id": "excerpt_words", "label": "Excerpt length (words, when no manual excerpt)", "min": 10, "max": 80, "step": 5, "default": 40 },
    { "type": "text", "id": "read_more_label", "label": "Read more label", "default": "Read More" },
    { "type": "range", "id": "column_gap", "label": "Column gap", "min": 16, "max": 96, "step": 4, "unit": "px", "default": 56 },
    { "type": "range", "id": "row_gap", "label": "Row gap", "min": 16, "max": 120, "step": 4, "unit": "px", "default": 72 },
    { "type": "header", "content": "Appearance" },
    { "type": "color", "id": "background_color", "label": "Background", "default": "#ffffff" },
    { "type": "color", "id": "heading_color", "label": "Heading & title color", "default": "#606452" },
    { "type": "color", "id": "text_color", "label": "Body text color", "default": "#606452" },
    { "type": "color", "id": "meta_color", "label": "Date color", "default": "#8a8a7a" },
    { "type": "color", "id": "link_color", "label": "Read more / link color", "default": "#b1a45a" },
    { "type": "range", "id": "max_width", "label": "Max width", "min": 900, "max": 1600, "step": 20, "unit": "px", "default": 1320 },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 64 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 80 }
  ]
}
{% endschema %}
