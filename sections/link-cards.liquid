{%- liquid
  assign s = section.settings
-%}
<style>
  #shopify-section-{{ section.id }} .cmn-cards {
    background-color: {{ s.background_color }};
    padding-block: {{ s.padding_top }}px {{ s.padding_bottom }}px;
  }
  #shopify-section-{{ section.id }} .cmn-cards__wrap {
    max-width: {{ s.max_width }}px;
    margin-inline: auto;
    padding-inline: 24px;
  }
  #shopify-section-{{ section.id }} .cmn-cards__heading {
    margin: 0 0 3rem;
    text-align: center;
    color: {{ s.heading_color }};
  }
  #shopify-section-{{ section.id }} .cmn-cards__grid {
    display: grid;
    grid-template-columns: repeat({{ s.columns }}, 1fr);
    gap: {{ s.row_gap }}px {{ s.column_gap }}px;
  }
  #shopify-section-{{ section.id }} .cmn-cards__card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }
  #shopify-section-{{ section.id }} .cmn-cards__media {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: {{ s.image_height }}px;
    margin-bottom: 1rem;
  }
  #shopify-section-{{ section.id }} .cmn-cards__media img {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
  }
  #shopify-section-{{ section.id }} .cmn-cards__caption {
    color: {{ s.link_color }};
    text-decoration: underline;
    font-size: 1.1rem;
    line-height: 1.4;
    max-width: 24ch;
  }
  @media (max-width: 749px) {
    #shopify-section-{{ section.id }} .cmn-cards__grid { grid-template-columns: 1fr; }
    #shopify-section-{{ section.id }} .cmn-cards__heading { margin-bottom: 2rem; }
  }
</style>

<div class="cmn-cards">
  <div class="cmn-cards__wrap">
    {%- if s.heading != blank -%}
      <{{ s.heading_tag }} class="cmn-cards__heading">{{ s.heading }}</{{ s.heading_tag }}>
    {%- endif -%}
    {%- if section.blocks.size > 0 -%}
      <div class="cmn-cards__grid">
        {%- for block in section.blocks -%}
          {%- assign b = block.settings -%}
          {%- liquid
            assign img_src = ''
            if b.image != blank
              assign img_src = b.image | image_url: width: 1000
            elsif b.image_asset != blank
              assign img_src = b.image_asset | asset_url
            endif
          -%}
          <div class="cmn-cards__card" {{ block.shopify_attributes }}>
            {%- if img_src != blank -%}
              <a class="cmn-cards__media" href="{{ b.link }}"{% if b.new_tab %} target="_blank" rel="noopener"{% endif %} aria-label="{{ b.label | escape }}">
                <img src="{{ img_src }}" loading="lazy" alt="{{ b.label | escape }}">
              </a>
            {%- endif -%}
            {%- if b.label != blank -%}
              <a class="cmn-cards__caption" href="{{ b.link }}"{% if b.new_tab %} target="_blank" rel="noopener"{% endif %}>{{ b.label }}</a>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Link cards",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading" },
    {
      "type": "select", "id": "heading_tag", "label": "Heading tag", "default": "h1",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" }
      ]
    },
    { "type": "header", "content": "Layout" },
    { "type": "range", "id": "columns", "label": "Columns", "min": 1, "max": 4, "step": 1, "default": 3 },
    { "type": "range", "id": "image_height", "label": "Image box height", "min": 120, "max": 360, "step": 10, "unit": "px", "default": 220 },
    { "type": "range", "id": "column_gap", "label": "Column gap", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 48 },
    { "type": "range", "id": "row_gap", "label": "Row gap", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 64 },
    { "type": "range", "id": "max_width", "label": "Content max width", "min": 700, "max": 1400, "step": 20, "unit": "px", "default": 1100 },
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "background_color", "label": "Background", "default": "#ffffff" },
    { "type": "color", "id": "heading_color", "label": "Heading", "default": "#606452" },
    { "type": "color", "id": "link_color", "label": "Caption link", "default": "#b1a45a" },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 80 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 96 }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "image_asset", "label": "Image asset filename (fallback)" },
        { "type": "text", "id": "label", "label": "Caption / link text" },
        { "type": "url", "id": "link", "label": "Link" },
        { "type": "checkbox", "id": "new_tab", "label": "Open in new tab", "default": false }
      ]
    }
  ],
  "presets": [{ "name": "Link cards" }]
}
{% endschema %}
