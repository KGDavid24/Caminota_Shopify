{%- liquid
  assign s = section.settings
-%}
<style>
  #shopify-section-{{ section.id }} .cmn-cert {
    background-color: {{ s.background_color }};
    padding-block: {{ s.padding_top }}px {{ s.padding_bottom }}px;
  }
  #shopify-section-{{ section.id }} .cmn-cert__wrap { max-width: 1320px; margin-inline: auto; padding-inline: 24px; }
  #shopify-section-{{ section.id }} .cmn-cert__heading { text-align: center; margin: 0 0 2.5rem; }
  #shopify-section-{{ section.id }} .cmn-cert__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px; }
  #shopify-section-{{ section.id }} .cmn-cert__card {
    background-color: {{ s.card_color }};
    padding: 2.5rem 1.5rem;
    text-align: center;
  }
  #shopify-section-{{ section.id }} .cmn-cert__title { margin: 0 0 1.5rem; }
  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .cmn-cert__grid { grid-template-columns: 1fr; gap: 24px; }
  }
</style>

<div class="cmn-cert">
  <div class="cmn-cert__wrap">
    {%- if s.heading != blank -%}
      <h2 class="cmn-cert__heading">{{ s.heading }}</h2>
    {%- endif -%}
    <div class="cmn-cert__grid">
      {%- for block in section.blocks -%}
        <div class="cmn-cert__card" {{ block.shopify_attributes }}>
          {%- if block.settings.title != blank -%}
            <h3 class="cmn-cert__title">{{ block.settings.title }}</h3>
          {%- endif -%}
          {%- if block.settings.button_label != blank -%}
            {%- assign target = block.settings.button_link -%}
            {%- if block.settings.file != blank -%}{%- assign target = block.settings.file -%}{%- endif -%}
            <a class="button" {% if target != blank %}href="{{ target }}"{% endif %} target="_blank" rel="noopener">{{ block.settings.button_label }}</a>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Home certifications",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Certificări și alte tehnicalități" },
    { "type": "header", "content": "Appearance" },
    { "type": "color", "id": "background_color", "label": "Background", "default": "#ffffff" },
    { "type": "color", "id": "card_color", "label": "Card background", "default": "#f4f2e4" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 48 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 72 }
  ],
  "blocks": [
    {
      "type": "cert",
      "name": "Certification",
      "settings": [
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "text", "id": "button_label", "label": "Button label", "default": "Download" },
        { "type": "url", "id": "button_link", "label": "Button link (page/URL)" },
        { "type": "url", "id": "file", "label": "File (overrides link if set)", "info": "Pick an uploaded PDF from Files" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Home certifications",
      "blocks": [
        { "type": "cert", "settings": { "title": "Fișe tehnice și instrucțiuni", "button_label": "Link" } },
        { "type": "cert", "settings": { "title": "Agrement tehnic", "button_label": "Download" } },
        { "type": "cert", "settings": { "title": "Certificat ISO 9001:2015", "button_label": "Download" } }
      ]
    }
  ]
}
{% endschema %}
