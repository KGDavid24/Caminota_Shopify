{%- liquid
  assign s = section.settings
-%}
<style>
  #shopify-section-{{ section.id }} .cmn-rt {
    background-color: {{ s.background_color }};
    padding-block: {{ s.padding_top }}px {{ s.padding_bottom }}px;
  }
  #shopify-section-{{ section.id }} .cmn-rt__wrap {
    max-width: {{ s.max_width }}px;
    margin-inline: auto;
    padding-inline: 24px;
    text-align: {{ s.alignment }};
  }
  #shopify-section-{{ section.id }} .cmn-rt__heading { margin: 0 0 1.25rem; color: {{ s.heading_color }}; text-align: {% if s.alignment == 'justify' %}left{% else %}{{ s.alignment }}{% endif %}; }
  #shopify-section-{{ section.id }} .cmn-rt__video { max-width: {{ s.video_width }}px; margin: 2rem auto; }
  #shopify-section-{{ section.id }} .cmn-rt__video-inner { position: relative; padding-bottom: 56.25%; height: 0; overflow: hidden; border-radius: 4px; }
  #shopify-section-{{ section.id }} .cmn-rt__video-inner iframe { position: absolute; inset: 0; width: 100%; height: 100%; border: 0; }
  #shopify-section-{{ section.id }} .cmn-rt__float { float: {{ s.float_position }}; width: {{ s.float_width }}px; max-width: 65%; {% if s.float_position == 'left' %}margin: 0.25rem {{ s.float_gap }}px 1rem 0;{% else %}margin: 0.25rem 0 1rem {{ s.float_gap }}px;{% endif %} }
  #shopify-section-{{ section.id }} .cmn-rt__float img { width: 100%; height: auto; display: block; }
  #shopify-section-{{ section.id }} .cmn-rt__float-caption { text-align: center; margin: 0.75rem 0 0; font-size: 0.95rem; }
  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .cmn-rt__float { float: none; width: 100%; max-width: none; margin: 0 0 1.5rem; }
  }
  #shopify-section-{{ section.id }} .cmn-rt__body { font-size: 1.05rem; line-height: 1.7; }
  #shopify-section-{{ section.id }} .cmn-rt__body p { margin: 0 0 1rem; }
  #shopify-section-{{ section.id }} .cmn-rt__body a { color: {{ settings.brand_gold }}; text-decoration: underline; }
  #shopify-section-{{ section.id }} .cmn-rt__body ul, #shopify-section-{{ section.id }} .cmn-rt__body ol { margin: 0 0 1rem; padding-left: 1.5rem; }
  #shopify-section-{{ section.id }} .cmn-rt__body li { margin-bottom: 0.4rem; }
</style>

<div class="cmn-rt">
  <div class="cmn-rt__wrap">
    {%- capture float_html -%}
      {%- if s.float_image != blank or s.float_image_asset != blank -%}
        <div class="cmn-rt__float">
          {%- if s.float_image != blank -%}
            {{ s.float_image | image_url: width: 700 | image_tag: loading: 'lazy', widths: '300, 500, 700' }}
          {%- else -%}
            <img src="{{ s.float_image_asset | asset_url }}" loading="lazy" alt="">
          {%- endif -%}
          {%- if s.float_caption != blank -%}<p class="cmn-rt__float-caption">{{ s.float_caption }}</p>{%- endif -%}
        </div>
      {%- endif -%}
    {%- endcapture -%}
    {%- if s.float_top -%}{{ float_html }}{%- endif -%}
    {%- if s.heading != blank -%}
      {%- case s.heading_tag -%}
        {%- when 'h1' -%}<h1 class="cmn-rt__heading">{{ s.heading }}</h1>
        {%- when 'h3' -%}<h3 class="cmn-rt__heading">{{ s.heading }}</h3>
        {%- when 'h4' -%}<h4 class="cmn-rt__heading">{{ s.heading }}</h4>
        {%- else -%}<h2 class="cmn-rt__heading">{{ s.heading }}</h2>
      {%- endcase -%}
    {%- endif -%}
    {%- if s.youtube_id != blank -%}
      <div class="cmn-rt__video">
        <div class="cmn-rt__video-inner">
          <iframe src="https://www.youtube.com/embed/{{ s.youtube_id }}" title="{{ s.heading | escape }}" loading="lazy" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
        </div>
      </div>
    {%- endif -%}
    {%- unless s.float_top -%}{{ float_html }}{%- endunless -%}
    {%- if s.body != blank -%}
      <div class="cmn-rt__body">{{ s.body }}</div>
    {%- endif -%}
    {%- if s.button_label != blank -%}
      <div class="cmn-rt__cta" style="text-align: center; margin-top: 1.5rem;">
        <a class="button" style="background-color: {{ settings.brand_gold }}; color: #ffffff; width: fit-content; margin-inline: auto; padding-inline: 2.25rem; padding-block: 0.9rem;" {% if s.button_link != blank %}href="{{ s.button_link }}"{% endif %}>{{ s.button_label }}</a>
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Rich text",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading" },
    { "type": "select", "id": "heading_tag", "label": "Heading level", "options": [{ "value": "h1", "label": "H1" }, { "value": "h2", "label": "H2" }, { "value": "h3", "label": "H3" }, { "value": "h4", "label": "H4" }], "default": "h2" },
    { "type": "richtext", "id": "body", "label": "Body" },
    { "type": "text", "id": "button_label", "label": "Button label (optional)" },
    { "type": "url", "id": "button_link", "label": "Button link" },
    { "type": "header", "content": "Video" },
    { "type": "text", "id": "youtube_id", "label": "YouTube video ID" },
    { "type": "range", "id": "video_width", "label": "Video max width", "min": 320, "max": 1000, "step": 20, "unit": "px", "default": 640 },
    { "type": "header", "content": "Float image" },
    { "type": "select", "id": "float_position", "label": "Image side", "options": [{ "value": "right", "label": "Right" }, { "value": "left", "label": "Left" }], "default": "right" },
    { "type": "checkbox", "id": "float_top", "label": "Image starts at top (heading beside it)", "default": false },
    { "type": "image_picker", "id": "float_image", "label": "Image" },
    { "type": "text", "id": "float_image_asset", "label": "Image asset filename (fallback)" },
    { "type": "range", "id": "float_width", "label": "Image max width", "min": 160, "max": 760, "step": 20, "unit": "px", "default": 320 },
    { "type": "text", "id": "float_caption", "label": "Image caption" },
    { "type": "range", "id": "float_gap", "label": "Gap between image and text", "min": 0, "max": 96, "step": 4, "unit": "px", "default": 32 },
    { "type": "select", "id": "alignment", "label": "Alignment", "options": [{ "value": "left", "label": "Left" }, { "value": "center", "label": "Center" }, { "value": "justify", "label": "Justify" }], "default": "left" },
    { "type": "range", "id": "max_width", "label": "Max width", "min": 500, "max": 1400, "step": 20, "unit": "px", "default": 820 },
    { "type": "header", "content": "Appearance" },
    { "type": "color", "id": "heading_color", "label": "Heading color", "default": "#606452" },
    { "type": "color", "id": "background_color", "label": "Background", "default": "#ffffff" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 48 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 48 }
  ],
  "presets": [{ "name": "Rich text" }]
}
{% endschema %}
