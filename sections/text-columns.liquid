{%- liquid
  assign s = section.settings
-%}
<style>
  #shopify-section-{{ section.id }} .cmn-cols {
    background-color: {{ s.background_color }};
    padding-block: {{ s.padding_top }}px {{ s.padding_bottom }}px;
  }
  #shopify-section-{{ section.id }} .cmn-cols__wrap {
    max-width: {{ s.max_width }}px;
    margin-inline: auto;
    padding-inline: 24px;
    display: grid;
    grid-template-columns: repeat({{ section.blocks.size }}, 1fr);
    gap: {{ s.gap }}px;
    align-items: start;
  }
  #shopify-section-{{ section.id }} .cmn-cols__heading { margin: 0 0 1.25rem; color: {{ s.heading_color }}; }
  #shopify-section-{{ section.id }} .cmn-cols__body { font-size: 1.05rem; line-height: 1.7; color: {{ s.text_color }}; }
  #shopify-section-{{ section.id }} .cmn-cols__body p { margin: 0 0 1rem; }
  #shopify-section-{{ section.id }} .cmn-cols__body a { color: {{ settings.brand_gold }}; text-decoration: underline; }
  #shopify-section-{{ section.id }} .cmn-cols__body ul, #shopify-section-{{ section.id }} .cmn-cols__body ol { margin: 0 0 1rem; padding-left: 1.5rem; }
  #shopify-section-{{ section.id }} .cmn-cols__body li { margin-bottom: 0.4rem; }
  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .cmn-cols__wrap { grid-template-columns: 1fr; gap: 40px; }
  }
</style>

<div class="cmn-cols">
  <div class="cmn-cols__wrap">
    {%- for block in section.blocks -%}
      <div class="cmn-cols__col" {{ block.shopify_attributes }}>
        {%- if block.settings.heading != blank -%}
          {%- case block.settings.heading_tag -%}
            {%- when 'h3' -%}<h3 class="cmn-cols__heading">{{ block.settings.heading }}</h3>
            {%- when 'h4' -%}<h4 class="cmn-cols__heading">{{ block.settings.heading }}</h4>
            {%- else -%}<h2 class="cmn-cols__heading">{{ block.settings.heading }}</h2>
          {%- endcase -%}
        {%- endif -%}
        {%- if block.settings.body != blank -%}
          <div class="cmn-cols__body">{{ block.settings.body }}</div>
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Text columns",
  "tag": "section",
  "settings": [
    { "type": "range", "id": "max_width", "label": "Max width", "min": 800, "max": 1600, "step": 20, "unit": "px", "default": 1200 },
    { "type": "range", "id": "gap", "label": "Column gap", "min": 24, "max": 120, "step": 4, "unit": "px", "default": 64 },
    { "type": "header", "content": "Appearance" },
    { "type": "color", "id": "background_color", "label": "Background", "default": "#ffffff" },
    { "type": "color", "id": "heading_color", "label": "Heading color", "default": "#606452" },
    { "type": "color", "id": "text_color", "label": "Body text color", "default": "#606452" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 64 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 64 }
  ],
  "blocks": [
    {
      "type": "column",
      "name": "Column",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading" },
        { "type": "select", "id": "heading_tag", "label": "Heading tag", "options": [{ "value": "h2", "label": "H2" }, { "value": "h3", "label": "H3" }, { "value": "h4", "label": "H4" }], "default": "h2" },
        { "type": "richtext", "id": "body", "label": "Body" }
      ]
    }
  ],
  "presets": [{ "name": "Text columns", "blocks": [{ "type": "column" }, { "type": "column" }] }]
}
{% endschema %}
