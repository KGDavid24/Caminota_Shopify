{%- liquid
  assign s = section.settings
  assign bg = s.background_color
-%}
<style>
  #shopify-section-{{ section.id }} .cmn-hero {
    position: relative;
    background-color: {{ bg }};
  }
  #shopify-section-{{ section.id }} .cmn-hero__media img {
    width: 100%;
    height: auto;
    max-height: 660px;
    object-fit: cover;
    object-position: center;
    display: block;
  }
  #shopify-section-{{ section.id }} .cmn-hero__overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
  }
  #shopify-section-{{ section.id }} .cmn-hero__container {
    width: 100%;
    max-width: 1320px;
    margin-inline: auto;
    padding-inline: 24px;
  }
  #shopify-section-{{ section.id }} .cmn-hero__content {
    max-width: min(480px, 38vw);
  }
  #shopify-section-{{ section.id }} .cmn-hero__heading {
    margin: 0;
    font-size: clamp(2.5rem, 3.4vw, 3.75rem);
    line-height: 1.2;
  }
  #shopify-section-{{ section.id }} .cmn-hero__tagline {
    font-family: var(--font-h2--family);
    color: {{ settings.brand_green }};
    font-size: clamp(1.25rem, 1.5vw, 1.5rem);
    line-height: 1.3;
    margin: 0.5rem 0 1.5rem;
  }
  #shopify-section-{{ section.id }} .cmn-hero__body {
    font-size: clamp(1.05rem, 1.35vw, 1.4rem);
    line-height: 1.7;
  }
  #shopify-section-{{ section.id }} .cmn-hero__body p { margin: 0; }
  #shopify-section-{{ section.id }} .cmn-hero__cta { margin-top: 1.75rem; }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .cmn-hero__media img { max-height: none; }
    #shopify-section-{{ section.id }} .cmn-hero__overlay { position: static; }
    #shopify-section-{{ section.id }} .cmn-hero__container { padding-block: 32px; }
    #shopify-section-{{ section.id }} .cmn-hero__content { max-width: none; }
  }
</style>

<div class="cmn-hero">
  <div class="cmn-hero__media">
    {%- if s.image != blank -%}
      {{ s.image | image_url: width: 1843 | image_tag: loading: 'eager', sizes: '100vw', widths: '900, 1300, 1600, 1843' }}
    {%- endif -%}
  </div>
  <div class="cmn-hero__overlay">
    <div class="cmn-hero__container">
      <div class="cmn-hero__content">
        {%- if s.heading != blank -%}
          <h1 class="cmn-hero__heading">{{ s.heading }}</h1>
        {%- endif -%}
        {%- if s.tagline != blank -%}
          <p class="cmn-hero__tagline">{{ s.tagline }}</p>
        {%- endif -%}
        {%- if s.body != blank -%}
          <div class="cmn-hero__body">{{ s.body }}</div>
        {%- endif -%}
        {%- if s.button_label != blank -%}
          <p class="cmn-hero__cta">
            <a class="button" {% if s.button_link != blank %}href="{{ s.button_link }}"{% endif %}>{{ s.button_label }}</a>
          </p>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Home hero",
  "tag": "section",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Hero image (collage)" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "caminota" },
    { "type": "text", "id": "tagline", "label": "Tagline", "default": "Case care inspiră." },
    { "type": "richtext", "id": "body", "label": "Body", "default": "<p><strong>caminotă, s.f.</strong> = 1. Tencuială naturală pe bază de argilă, pentru case tradiționale și locuințe moderne. 2. Fig. Îmbrăcăminte naturală și sănătoasă pentru orice perete.</p>" },
    { "type": "text", "id": "button_label", "label": "Button label" },
    { "type": "url", "id": "button_link", "label": "Button link" },
    { "type": "header", "content": "Appearance" },
    { "type": "color", "id": "background_color", "label": "Background / text-side tint", "default": "#f4f2e4" }
  ],
  "presets": [{ "name": "Home hero" }]
}
{% endschema %}
