{%- liquid
  assign s = section.settings
-%}
<style>
  #shopify-section-{{ section.id }} .cmn-faq {
    background-color: {{ s.background_color }};
    padding-block: {{ s.padding_top }}px {{ s.padding_bottom }}px;
  }
  #shopify-section-{{ section.id }} .cmn-faq__wrap {
    max-width: {{ s.max_width }}px;
    margin-inline: auto;
    padding-inline: 24px;
  }
  #shopify-section-{{ section.id }} .cmn-faq__heading {
    text-align: center;
    color: {{ s.heading_color }};
    margin: 0 0 3rem;
  }
  #shopify-section-{{ section.id }} details {
    border-top: 1px solid #e7e4d4;
  }
  #shopify-section-{{ section.id }} details:last-child {
    border-bottom: 1px solid #e7e4d4;
  }
  #shopify-section-{{ section.id }} summary {
    list-style: none;
    cursor: pointer;
    padding: 1.25rem 0;
    font-weight: 600;
    color: {{ s.question_color }};
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    font-size: 1.05rem;
    line-height: 1.4;
  }
  #shopify-section-{{ section.id }} summary::-webkit-details-marker { display: none; }
  #shopify-section-{{ section.id }} summary::after {
    content: '+';
    font-size: 1.5rem;
    font-weight: 300;
    flex-shrink: 0;
    color: {{ s.question_color }};
  }
  #shopify-section-{{ section.id }} details[open] > summary::after {
    content: '−';
  }
  #shopify-section-{{ section.id }} .cmn-faq__answer {
    padding: 0 2rem 1.5rem 0;
    color: #444;
    line-height: 1.75;
    font-size: 1rem;
  }
  #shopify-section-{{ section.id }} .cmn-faq__answer p { margin: 0 0 0.75rem; }
  #shopify-section-{{ section.id }} .cmn-faq__answer p:last-child { margin-bottom: 0; }
  #shopify-section-{{ section.id }} .cmn-faq__answer ul,
  #shopify-section-{{ section.id }} .cmn-faq__answer ol {
    margin: 0.5rem 0 0.75rem;
    padding-left: 1.5rem;
  }
  #shopify-section-{{ section.id }} .cmn-faq__answer li { margin-bottom: 0.4rem; }
  #shopify-section-{{ section.id }} .cmn-faq__answer a {
    color: {{ settings.brand_gold }};
    text-decoration: underline;
  }
</style>

<div class="cmn-faq">
  <div class="cmn-faq__wrap">
    {%- if s.heading != blank -%}
      <h1 class="cmn-faq__heading">{{ s.heading }}</h1>
    {%- endif -%}
    {%- if section.blocks.size > 0 -%}
      <div class="cmn-faq__list">
        {%- for block in section.blocks -%}
          {%- assign b = block.settings -%}
          <details {{ block.shopify_attributes }}>
            <summary>{{ b.question | escape }}</summary>
            <div class="cmn-faq__answer">{{ b.answer }}</div>
          </details>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "FAQ",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Întrebări frecvente" },
    { "type": "header", "content": "Layout" },
    { "type": "range", "id": "max_width", "label": "Content max width", "min": 600, "max": 1200, "step": 20, "unit": "px", "default": 800 },
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "background_color", "label": "Background", "default": "#ffffff" },
    { "type": "color", "id": "heading_color", "label": "Heading color", "default": "#606452" },
    { "type": "color", "id": "question_color", "label": "Question color", "default": "#606452" },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 80 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 96 }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "FAQ item",
      "settings": [
        { "type": "text", "id": "question", "label": "Question" },
        { "type": "richtext", "id": "answer", "label": "Answer" }
      ]
    }
  ],
  "presets": [{ "name": "FAQ" }]
}
{% endschema %}
