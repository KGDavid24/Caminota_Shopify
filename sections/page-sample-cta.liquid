{%- liquid
  assign s = section.settings
-%}
<style>
  #shopify-section-{{ section.id }} .cmn-sample {
    background-color: {{ s.background_color }};
    padding-block: {{ s.padding_top }}px {{ s.padding_bottom }}px;
  }
  #shopify-section-{{ section.id }} .cmn-sample__inner {
    max-width: 1160px;
    margin-inline: auto;
    padding-inline: 24px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 56px;
    align-items: center;
  }
  #shopify-section-{{ section.id }} .cmn-sample__media { text-align: center; }
  #shopify-section-{{ section.id }} .cmn-sample__media img { max-width: {{ s.image_max_width }}px; width: 100%; height: auto; display: block; margin-inline: auto; }
  {% if s.image_position == 'right' %}
  #shopify-section-{{ section.id }} .cmn-sample__media { order: 2; }
  {% endif %}
  #shopify-section-{{ section.id }} .cmn-sample__heading { margin: 0 0 1.5rem; color: {{ s.heading_color }}; }
  #shopify-section-{{ section.id }} .cmn-sample__body { font-size: 1.15rem; line-height: 1.7; color: {{ s.text_color }}; }
  #shopify-section-{{ section.id }} .cmn-sample__cta { margin-top: 1.75rem; text-align: center; }
  #shopify-section-{{ section.id }} .cmn-sample__cta a.button {
    background-color: {{ s.button_bg }};
    color: {{ s.button_text }};
    width: fit-content;
    margin-inline: auto;
    padding-inline: 2.25rem;
    padding-block: 0.9rem;
  }
  #shopify-section-{{ section.id }} .cmn-sample__footnote { margin-top: 1.25rem; font-size: 0.9rem; font-style: italic; color: {{ s.footnote_color }}; text-align: center; }
  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .cmn-sample__inner { grid-template-columns: 1fr; gap: 32px; }
    #shopify-section-{{ section.id }} .cmn-sample__media { order: -1; }
  }
</style>

<div class="cmn-sample">
  <div class="cmn-sample__inner">
    <div class="cmn-sample__media">
      {%- if s.image != blank -%}
        {{ s.image | image_url: width: 1000 | image_tag: loading: 'lazy', sizes: '(min-width: 750px) 50vw, 100vw', widths: '400, 700, 1000' }}
      {%- endif -%}
    </div>
    <div class="cmn-sample__content">
      {%- if s.heading != blank -%}
        <h2 class="cmn-sample__heading">{{ s.heading }}</h2>
      {%- endif -%}
      {%- if s.body != blank -%}
        <div class="cmn-sample__body">{{ s.body }}</div>
      {%- endif -%}
      {%- if s.button_label != blank -%}
        <div class="cmn-sample__cta">
          <a class="button" {% if s.button_link != blank %}href="{{ s.button_link }}"{% endif %} target="_blank" rel="noopener">{{ s.button_label }}</a>
        </div>
      {%- endif -%}
      {%- if s.footnote != blank -%}
        <p class="cmn-sample__footnote">{{ s.footnote }}</p>
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Page sample CTA",
  "tag": "section",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "range", "id": "image_max_width", "label": "Image max width", "min": 240, "max": 700, "step": 20, "unit": "px", "default": 480 },
    { "type": "select", "id": "image_position", "label": "Image position", "options": [{ "value": "left", "label": "Left" }, { "value": "right", "label": "Right" }], "default": "left" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Probează Caminota" },
    { "type": "richtext", "id": "body", "label": "Body", "default": "<p>Înainte de a lua o decizie, e normal să vrei să vezi și să atingi materialul. Așa că facem să-ți fie mai ușor și îți punem la dispoziție posibilitatea de a încerca mai întâi Caminota. Comandă de pe eMAG un kit de încercare, iar după o zi-două poți proba produsele. Noi nu mai zicem nimic, le lăsăm pe ele să-ți vorbească.</p>" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Comandă o mostră de Caminota" },
    { "type": "url", "id": "button_link", "label": "Button link" },
    { "type": "text", "id": "footnote", "label": "Footnote", "default": "* Pentru cantități mai mari livrăm direct din fabrică la șantier, contactați-ne!" },
    { "type": "header", "content": "Appearance" },
    { "type": "color", "id": "background_color", "label": "Background", "default": "#ffffff" },
    { "type": "color", "id": "heading_color", "label": "Heading color", "default": "#606452" },
    { "type": "color", "id": "text_color", "label": "Body text color", "default": "#606452" },
    { "type": "color", "id": "button_bg", "label": "Button background", "default": "#606452" },
    { "type": "color", "id": "button_text", "label": "Button text", "default": "#ffffff" },
    { "type": "color", "id": "footnote_color", "label": "Footnote color", "default": "#b1a45a" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 72 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 72 }
  ],
  "presets": [{ "name": "Page sample CTA" }]
}
{% endschema %}
