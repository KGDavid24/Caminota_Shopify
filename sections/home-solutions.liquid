{%- liquid
  assign s = section.settings
-%}
<style>
  #shopify-section-{{ section.id }} .cmn-sol {
    background-color: {{ s.background_color }};
    padding-block: {{ s.padding_top }}px {{ s.padding_bottom }}px;
  }
  #shopify-section-{{ section.id }} .cmn-sol__wrap { max-width: 1320px; margin-inline: auto; padding-inline: 24px; }
  #shopify-section-{{ section.id }} .cmn-sol__heading { text-align: center; margin: 0 0 4rem; }
  #shopify-section-{{ section.id }} .cmn-sol__grid {
    display: grid;
    grid-template-columns: repeat({{ s.columns }}, 1fr);
    gap: 48px;
  }
  #shopify-section-{{ section.id }} .cmn-card__media img { width: 100%; height: auto; display: block; aspect-ratio: 16 / 10; object-fit: cover; }
  #shopify-section-{{ section.id }} .cmn-card__title { color: {{ settings.brand_gold }}; margin: 3.5rem 0 0.75rem; font-size: 2.65rem; margin-bottom: 1.8rem; }
  #shopify-section-{{ section.id }} .cmn-card__text { margin: 0 0 3rem; }
  #shopify-section-{{ section.id }} .cmn-card__cta { display: flex; justify-content: center; }
  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .cmn-sol__grid { grid-template-columns: 1fr; gap: 40px; }
  }
</style>

<div class="cmn-sol">
  <div class="cmn-sol__wrap">
    {%- if s.heading != blank -%}
      <h2 class="cmn-sol__heading">{{ s.heading }}</h2>
    {%- endif -%}
    <div class="cmn-sol__grid">
      {%- for block in section.blocks -%}
        <div class="cmn-card" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            <div class="cmn-card__media">
              {{ block.settings.image | image_url: width: 800 | image_tag: loading: 'lazy', sizes: '(min-width: 750px) 45vw, 100vw', widths: '400, 600, 800' }}
            </div>
          {%- endif -%}
          {%- if block.settings.title != blank -%}
            <h3 class="cmn-card__title">{{ block.settings.title }}</h3>
          {%- endif -%}
          {%- if block.settings.text != blank -%}
            <div class="cmn-card__text">{{ block.settings.text }}</div>
          {%- endif -%}
          {%- if block.settings.link_label != blank -%}
            <p class="cmn-card__cta">
              <a class="button-secondary" {% if block.settings.link_url != blank %}href="{{ block.settings.link_url }}"{% endif %}>{{ block.settings.link_label }}</a>
            </p>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Home solutions",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Caminota face casă bună cu" },
    { "type": "range", "id": "columns", "label": "Columns (desktop)", "min": 2, "max": 4, "step": 1, "default": 2 },
    { "type": "header", "content": "Appearance" },
    { "type": "color", "id": "background_color", "label": "Background", "default": "#ffffff" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 72 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 72 }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "richtext", "id": "text", "label": "Text" },
        { "type": "text", "id": "link_label", "label": "Button label", "default": "Află mai multe" },
        { "type": "url", "id": "link_url", "label": "Button link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Home solutions",
      "blocks": [
        { "type": "card", "settings": { "title": "Case tradiționale", "text": "<p>Sistemul Caminota soluția recomandată de specialiști pentru renovarea caselor vechi, cu pereți din chirpici, paiantă, lut, bârne din lemn sau cărămidă.</p>" } },
        { "type": "card", "settings": { "title": "Case moderne", "text": "<p>Sistemul Caminota este o soluție ecologică, sănătoasă și certificată pentru finisarea pereților caselor moderne din zidărie de cărămidă cu goluri, BCA, lemn, panouri, hempcrete samd.</p>" } }
      ]
    }
  ]
}
{% endschema %}
