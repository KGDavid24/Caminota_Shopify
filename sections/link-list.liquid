{%- liquid
  assign s = section.settings
-%}
<style>
  #shopify-section-{{ section.id }} .cmn-links {
    background-color: {{ s.background_color }};
    padding-block: {{ s.padding_top }}px {{ s.padding_bottom }}px;
  }
  #shopify-section-{{ section.id }} .cmn-links__wrap {
    max-width: 900px;
    margin-inline: auto;
    padding-inline: 24px;
  }
  #shopify-section-{{ section.id }} .cmn-links__heading { margin: 0 0 1.5rem; color: {{ settings.brand_olive }}; }
  #shopify-section-{{ section.id }} .cmn-links__intro { margin: 0 0 2rem; font-size: 1.05rem; line-height: 1.7; }
  #shopify-section-{{ section.id }} .cmn-links__list { list-style: none; margin: 0; padding: 0; }
  #shopify-section-{{ section.id }} .cmn-links__item { margin-bottom: 1rem; font-size: 1.1rem; line-height: 1.5; }
  #shopify-section-{{ section.id }} .cmn-links__item a { color: {{ settings.brand_gold }}; text-decoration: underline; }
  #shopify-section-{{ section.id }} .cmn-links__item span { color: {{ settings.brand_olive }}; }
</style>

<div class="cmn-links">
  <div class="cmn-links__wrap">
    {%- if s.heading != blank -%}
      <h2 class="cmn-links__heading">{{ s.heading }}</h2>
    {%- endif -%}
    {%- if s.intro != blank -%}
      <div class="cmn-links__intro">{{ s.intro }}</div>
    {%- endif -%}
    {%- if section.blocks.size > 0 -%}
      <ul class="cmn-links__list">
        {%- for block in section.blocks -%}
          {%- if block.settings.label != blank -%}
            <li class="cmn-links__item" {{ block.shopify_attributes }}>
              {%- if block.settings.url != blank -%}
                <a href="{{ block.settings.url }}"{% if block.settings.bold %} style="font-weight: 700;"{% endif %}>{{ block.settings.label }}</a>
              {%- else -%}
                <span{% if block.settings.bold %} style="font-weight: 700;"{% endif %}>{{ block.settings.label }}</span>
              {%- endif -%}
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Link list",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading" },
    { "type": "richtext", "id": "intro", "label": "Intro" },
    { "type": "header", "content": "Appearance" },
    { "type": "color", "id": "background_color", "label": "Background", "default": "#ffffff" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 72 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 72 }
  ],
  "blocks": [
    {
      "type": "link",
      "name": "Link",
      "settings": [
        { "type": "text", "id": "label", "label": "Label" },
        { "type": "url", "id": "url", "label": "URL (leave blank for plain text)" },
        { "type": "checkbox", "id": "bold", "label": "Bold", "default": false }
      ]
    }
  ],
  "presets": [{ "name": "Link list" }]
}
{% endschema %}
