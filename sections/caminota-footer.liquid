{%- liquid
  assign s = section.settings
-%}
<style>
  .cmn-footer {
    background-color: {{ s.background_color }};
    color: #ffffff;
    overflow: hidden;
  }
  .cmn-footer__main {
    max-width: 1100px;
    margin-inline: auto;
    padding: 36px 48px 32px;
    display: grid;
    grid-template-columns: 320px 1fr 1fr 1fr;
    gap: 40px 80px;
    align-items: stretch;
  }
  .cmn-footer__col-contact {
    display: flex;
    flex-direction: column;
  }
  .cmn-footer__logo-wrap {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 32px;
    margin-left: 0;
  }
  .cmn-footer__logo-img { height: 52px; width: auto; display: block; }
  .cmn-footer__wordmark {
    font-family: var(--font-heading--family);
    font-size: 1.6rem;
    color: #ffffff;
    letter-spacing: 0.06em;
  }
  .cmn-footer__contact { display: flex; flex-direction: column; gap: 14px; flex: 1; }
  .cmn-footer__contact p { margin: 0; font-size: 0.9rem; line-height: 1.5; }
  .cmn-footer__contact a { color: {{ s.accent_color }}; text-decoration: underline; }
  .cmn-footer__contact a:hover { opacity: 0.8; }
  .cmn-footer__social {
    display: flex;
    gap: 20px;
    margin-top: auto;
    padding-top: 40px;
    align-items: center;
  }
  .cmn-footer__social a { color: #ffffff; display: block; line-height: 0; }
  .cmn-footer__social svg { width: 20px; height: 20px; fill: currentColor; }
  .cmn-footer__col-nav {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .cmn-footer__nav { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 16px; }
  .cmn-footer__nav a { color: {{ s.accent_color }}; text-decoration: underline; font-size: 0.95rem; }
  .cmn-footer__nav a:hover { opacity: 0.8; }
  .cmn-footer__decor { display: flex; justify-content: flex-end; align-items: flex-start; overflow: visible; }
  .cmn-footer__decor img { width: 130%; max-width: none; height: auto; display: block; margin-top: -16px; margin-right: -80px; }
  .cmn-footer__bottom {
    border-top: 1px solid rgba(255,255,255,0.15);
    padding: 20px 48px;
    text-align: center;
    font-size: 0.85rem;
    color: rgba(255,255,255,0.75);
  }
  @media screen and (max-width: 989px) {
    .cmn-footer__main { grid-template-columns: 1fr 1fr; gap: 40px; }
  }
  @media screen and (max-width: 749px) {
    .cmn-footer__main { grid-template-columns: 1fr; padding: 40px 24px 32px; }
    .cmn-footer__bottom { padding-inline: 24px; }
  }
</style>

<div class="cmn-footer">
  <div class="cmn-footer__main">

    <!-- Col 1: Logo + contact + social -->
    <div class="cmn-footer__col-contact">
      <div class="cmn-footer__logo-wrap">
        {%- if settings.logo != blank -%}
          <img src="{{ settings.logo | image_url: width: 80 }}" alt="{{ shop.name }}" class="cmn-footer__logo-img">
        {%- endif -%}
        <span class="cmn-footer__wordmark">caminota</span>
      </div>
      <div class="cmn-footer__contact">
        {%- if s.phone_consult != blank -%}
          <p>Consultanță materiale: <a href="tel:{{ s.phone_consult | remove: ' ' }}">{{ s.phone_consult }}</a></p>
        {%- endif -%}
        {%- if s.phone_orders != blank -%}
          <p>Comenzi / livrări: <a href="tel:{{ s.phone_orders | remove: ' ' }}">{{ s.phone_orders }}</a></p>
        {%- endif -%}
        {%- if s.email != blank -%}
          <p>email: <a href="mailto:{{ s.email }}">{{ s.email }}</a></p>
        {%- endif -%}
      </div>
      <div class="cmn-footer__social">
        {%- if s.youtube_url != blank -%}
          <a href="{{ s.youtube_url }}" target="_blank" rel="noopener" aria-label="YouTube">
            <svg viewBox="0 0 24 24"><path d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.4.6A3 3 0 0 0 .5 6.2 31 31 0 0 0 0 12a31 31 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.1c1.9.6 9.4.6 9.4.6s7.5 0 9.4-.6a3 3 0 0 0 2.1-2.1A31 31 0 0 0 24 12a31 31 0 0 0-.5-5.8zM9.7 15.5V8.5l6.3 3.5-6.3 3.5z"/></svg>
          </a>
        {%- endif -%}
        {%- if s.facebook_url != blank -%}
          <a href="{{ s.facebook_url }}" target="_blank" rel="noopener" aria-label="Facebook">
            <svg viewBox="0 0 24 24"><path d="M22 12a10 10 0 1 0-11.6 9.9v-7H7.9V12h2.5V9.8c0-2.5 1.5-3.9 3.8-3.9 1.1 0 2.2.2 2.2.2v2.5h-1.3c-1.2 0-1.6.8-1.6 1.6V12h2.8l-.4 2.9h-2.4v7A10 10 0 0 0 22 12z"/></svg>
          </a>
        {%- endif -%}
        {%- if s.instagram_url != blank -%}
          <a href="{{ s.instagram_url }}" target="_blank" rel="noopener" aria-label="Instagram">
            <svg viewBox="0 0 24 24"><path d="M12 2.2c3.2 0 3.6 0 4.9.1 3.3.1 4.8 1.7 4.9 4.9.1 1.3.1 1.6.1 4.8 0 3.2 0 3.6-.1 4.8-.1 3.2-1.7 4.8-4.9 4.9-1.3.1-1.6.1-4.9.1-3.2 0-3.6 0-4.8-.1-3.3-.1-4.8-1.7-4.9-4.9C2.2 15.6 2.2 15.2 2.2 12c0-3.2 0-3.6.1-4.8C2.4 3.9 4 2.3 7.2 2.3c1.2-.1 1.6-.1 4.8-.1zm0-2.2C8.7 0 8.3 0 7.1.1 2.7.3.3 2.7.1 7.1 0 8.3 0 8.7 0 12s0 3.7.1 4.9C.3 21.3 2.7 23.7 7.1 23.9 8.3 24 8.7 24 12 24s3.7 0 4.9-.1c4.4-.2 6.8-2.6 7-7 .1-1.2.1-1.6.1-4.9s0-3.7-.1-4.9C23.7 2.7 21.3.3 16.9.1 15.7 0 15.3 0 12 0zm0 5.8a6.2 6.2 0 1 0 0 12.4A6.2 6.2 0 0 0 12 5.8zm0 10.2a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.4-11.8a1.4 1.4 0 1 0 0 2.8 1.4 1.4 0 0 0 0-2.8z"/></svg>
          </a>
        {%- endif -%}
        {%- if s.email != blank -%}
          <a href="mailto:{{ s.email }}" aria-label="Email">
            <svg viewBox="0 0 24 24"><path d="M20 4H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2zm0 4-8 5-8-5V6l8 5 8-5v2z"/></svg>
          </a>
        {%- endif -%}
      </div>
    </div>

    <!-- Col 2: Nav links -->
    <div class="cmn-footer__col-nav">
      {%- if s.nav_menu != blank -%}
        <ul class="cmn-footer__nav">
          {%- for link in linklists[s.nav_menu].links -%}
            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {%- endfor -%}
        </ul>
      {%- endif -%}
    </div>

    <!-- Col 3: Legal links -->
    <div class="cmn-footer__col-nav">
      {%- if s.legal_menu != blank -%}
        <ul class="cmn-footer__nav">
          {%- for link in linklists[s.legal_menu].links -%}
            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {%- endfor -%}
        </ul>
      {%- endif -%}
    </div>

    <!-- Col 4: Decorative image -->
    <div class="cmn-footer__decor">
      {%- if s.decor_image != blank -%}
        {{ s.decor_image | image_url: width: 400 | image_tag: loading: 'lazy', alt: '' }}
      {%- endif -%}
    </div>

  </div>

  <div class="cmn-footer__bottom">
    {{ s.copyright }}
  </div>
</div>

{% schema %}
{
  "name": "Caminota Footer",
  "tag": "section",
  "settings": [
    { "type": "header", "content": "Contact" },
    { "type": "text", "id": "phone_consult", "label": "Phone – consultanță", "default": "0745 055 558" },
    { "type": "text", "id": "phone_orders", "label": "Phone – comenzi/livrări", "default": "0748 204 324" },
    { "type": "text", "id": "email", "label": "Email", "default": "contact@caminota.ro" },
    { "type": "header", "content": "Navigation" },
    { "type": "link_list", "id": "nav_menu", "label": "Nav links menu" },
    { "type": "link_list", "id": "legal_menu", "label": "Legal links menu" },
    { "type": "header", "content": "Social" },
    { "type": "url", "id": "youtube_url", "label": "YouTube URL" },
    { "type": "url", "id": "facebook_url", "label": "Facebook URL" },
    { "type": "url", "id": "instagram_url", "label": "Instagram URL" },
    { "type": "header", "content": "Decorative image" },
    { "type": "image_picker", "id": "decor_image", "label": "Decorative image (top right)" },
    { "type": "header", "content": "Appearance" },
    { "type": "color", "id": "background_color", "label": "Background", "default": "#606452" },
    { "type": "color", "id": "accent_color", "label": "Accent (links, wordmark)", "default": "#B1A45A" },
    { "type": "text", "id": "copyright", "label": "Copyright text", "default": "Copyright 2020 Caminota. Toate drepturile rezervate. Caminota este o marcă înregistrată." }
  ],
  "presets": [{ "name": "Caminota Footer" }]
}
{% endschema %}
