{%- liquid
  assign s = section.settings
-%}
<style>
  #shopify-section-{{ section.id }} .cmn-partners {
    background-color: {{ s.background_color }};
    padding-block: {{ s.padding_top }}px {{ s.padding_bottom }}px;
  }
  #shopify-section-{{ section.id }} .cmn-partners__wrap { max-width: 1100px; margin-inline: auto; padding-inline: 24px; }
  #shopify-section-{{ section.id }} .cmn-partners__heading { text-align: center; margin: 0 0 2.5rem; }
  #shopify-section-{{ section.id }} .cmn-partners__grid {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 56px;
  }
  #shopify-section-{{ section.id }} .cmn-partners__item img { max-height: {{ s.logo_height }}px; width: auto; display: block; }
</style>

<div class="cmn-partners">
  <div class="cmn-partners__wrap">
    {%- if s.heading != blank -%}
      <h2 class="cmn-partners__heading">{{ s.heading }}</h2>
    {%- endif -%}
    {%- if section.blocks.size > 0 -%}
      <div class="cmn-partners__grid">
        {%- for block in section.blocks -%}
          {%- if block.settings.image != blank -%}
            <div class="cmn-partners__item" {{ block.shopify_attributes }}>
              {%- if block.settings.link != blank -%}
                <a href="{{ block.settings.link }}" target="_blank" rel="noopener">
                  {{ block.settings.image | image_url: width: 400 | image_tag: loading: 'lazy', widths: '200, 400' }}
                </a>
              {%- else -%}
                {{ block.settings.image | image_url: width: 400 | image_tag: loading: 'lazy', widths: '200, 400' }}
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Home partners",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Parteneri" },
    { "type": "range", "id": "logo_height", "label": "Max logo height", "min": 40, "max": 160, "step": 4, "unit": "px", "default": 88 },
    { "type": "header", "content": "Appearance" },
    { "type": "color", "id": "background_color", "label": "Background", "default": "#ffffff" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 64 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 64 }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Logo" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Home partners",
      "blocks": [
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" }
      ]
    }
  ]
}
{% endschema %}
