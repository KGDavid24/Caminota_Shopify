{%- liquid
  assign s = section.settings
  assign overlay = s.overlay_opacity | times: 1.0 | divided_by: 100.0
-%}
<style>
  #shopify-section-{{ section.id }} .cmn-mission {
    position: relative;
    background-color: {{ s.fallback_color }};
    {% if s.background_image != blank %}
    background-image: url({{ s.background_image | image_url: width: 2000 }});
    background-size: cover;
    background-position: center;
    {% endif %}
    padding-block: {{ s.padding_top }}px {{ s.padding_bottom }}px;
    color: {{ s.text_color }};
    --color: {{ s.text_color }};
  }
  #shopify-section-{{ section.id }} .cmn-mission__overlay {
    position: absolute;
    inset: 0;
    background-color: {{ s.overlay_color }};
    opacity: {{ overlay }};
    pointer-events: none;
  }
  #shopify-section-{{ section.id }} .cmn-mission__inner {
    position: relative;
    max-width: 820px;
    margin-inline: auto;
    padding-inline: 24px;
    text-align: center;
  }
  #shopify-section-{{ section.id }} .cmn-mission__heading { margin: 0 0 1.75rem; }
  #shopify-section-{{ section.id }} .cmn-mission__body { text-align: left; }
</style>

<div class="cmn-mission">
  <div class="cmn-mission__overlay"></div>
  <div class="cmn-mission__inner">
    {%- if s.heading != blank -%}
      <h2 class="cmn-mission__heading">{{ s.heading }}</h2>
    {%- endif -%}
    {%- if s.body != blank -%}
      <div class="cmn-mission__body">{{ s.body }}</div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Home mission",
  "tag": "section",
  "settings": [
    { "type": "image_picker", "id": "background_image", "label": "Background image" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Misiune" },
    { "type": "richtext", "id": "body", "label": "Body", "default": "<p>Misiunea sau menirea noastră este de a pune umărul la <strong>“transhumanța” societății spre sustenabilitate</strong>, unde sustenabilitate = utilizarea responsabilă a resurselor naturale fără a conduce la epuizarea acestora sau la degradarea mediului înconjurător pentru generațiile care urmează.</p><p>Cum? Creând și punând la dispoziția creației (a se citi casei) tale <strong>produse manufăcute din natură</strong>, prietenoase cu mediul, dar și cu bugetul. Sistemul Caminota este compus din <strong>produse naturale, ecologice și locale</strong>, a căror producție necesită un consum de energie de zeci de ori mai mic decât materialele pe bază de ciment.</p>" },
    { "type": "header", "content": "Appearance" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#ffffff" },
    { "type": "color", "id": "fallback_color", "label": "Fallback background", "default": "#606452" },
    { "type": "color", "id": "overlay_color", "label": "Overlay color", "default": "#2c2e25" },
    { "type": "range", "id": "overlay_opacity", "label": "Overlay opacity", "min": 0, "max": 100, "step": 5, "unit": "%", "default": 45 },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 240, "step": 4, "unit": "px", "default": 96 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 240, "step": 4, "unit": "px", "default": 96 }
  ],
  "presets": [{ "name": "Home mission" }]
}
{% endschema %}
