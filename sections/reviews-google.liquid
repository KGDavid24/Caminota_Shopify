{%- liquid
  assign s = section.settings
-%}
<style>
  #shopify-section-{{ section.id }} .cmn-reviews {
    background-color: {{ s.background_color }};
    padding-block: {{ s.padding_top }}px {{ s.padding_bottom }}px;
  }
  #shopify-section-{{ section.id }} .cmn-reviews__wrap {
    max-width: {{ s.max_width }}px;
    margin-inline: auto;
    padding-inline: 24px;
  }
  #shopify-section-{{ section.id }} .cmn-reviews__heading {
    text-align: center;
    margin: 0 0 2rem;
    color: {{ s.heading_color }};
  }
</style>

<div class="cmn-reviews">
  <div class="cmn-reviews__wrap">
    {%- if s.heading != blank -%}
      <h2 class="cmn-reviews__heading">{{ s.heading }}</h2>
    {%- endif -%}
    {%- if s.embed_id != blank -%}
      <div class="sk-ww-google-reviews" data-embed-id="{{ s.embed_id }}"></div>
      <script src="https://widgets.sociablekit.com/google-reviews/widget.js" defer></script>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Google reviews",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading (optional)" },
    { "type": "text", "id": "embed_id", "label": "SociableKit embed ID", "default": "25510686" },
    { "type": "header", "content": "Appearance" },
    { "type": "color", "id": "background_color", "label": "Background", "default": "#b1a45a" },
    { "type": "color", "id": "heading_color", "label": "Heading color", "default": "#ffffff" },
    { "type": "range", "id": "max_width", "label": "Max width", "min": 900, "max": 1600, "step": 20, "unit": "px", "default": 1320 },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 64 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 64 }
  ],
  "presets": [{ "name": "Google reviews" }]
}
{% endschema %}
