{%- liquid
  assign s = section.settings
  assign grid_cols = 4
  assign base_ratio = '4 / 3'
  if s.layout == 'uniform'
    assign grid_cols = s.columns
    assign base_ratio = s.uniform_ratio
  endif
-%}
<style>
  #shopify-section-{{ section.id }} .cmn-bento {
    background-color: {{ s.background_color }};
    padding-block: {{ s.padding_top }}px {{ s.padding_bottom }}px;
  }
  #shopify-section-{{ section.id }} .cmn-bento__wrap {
    {% if s.max_width > 0 %}max-width: {{ s.max_width }}px; margin-inline: auto;{% endif %}
    padding-inline: {{ s.side_padding }}px;
  }
  #shopify-section-{{ section.id }} .cmn-bento__heading { margin: 0 0 2rem; padding-inline: {% if s.side_padding < 24 %}24{% else %}{{ s.side_padding }}{% endif %}px; color: {{ settings.brand_olive }}; }
  #shopify-section-{{ section.id }} .cmn-bento__item {
    padding: 0;
    border: none;
    margin: 0;
    background: none;
    cursor: pointer;
    overflow: hidden;
    border-radius: 0;
    aspect-ratio: {{ base_ratio }};
  }
  {%- if s.layout == 'uniform' -%}
  {%- assign gap_total = s.columns | minus: 1 | times: s.gap -%}
  /* Flex so an incomplete last row centers; full rows still fill exactly. */
  #shopify-section-{{ section.id }} .cmn-bento__grid {
    display: flex;
    flex-wrap: wrap;
    gap: {{ s.gap }}px;
    justify-content: center;
  }
  #shopify-section-{{ section.id }} .cmn-bento__item {
    width: calc((100% - {{ gap_total }}px) / {{ s.columns }});
  }
  {%- else -%}
  #shopify-section-{{ section.id }} .cmn-bento__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: {{ s.gap }}px;
    grid-auto-flow: dense;
  }
  /* Every 5th & 6th image in each cycle of 6 spans two columns (the larger bento tiles). */
  #shopify-section-{{ section.id }} .cmn-bento__item:nth-child(6n+5),
  #shopify-section-{{ section.id }} .cmn-bento__item:nth-child(6n+6) {
    grid-column: span 2;
    aspect-ratio: 8 / 5;
  }
  {%- endif -%}
  #shopify-section-{{ section.id }} .cmn-bento__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }
  #shopify-section-{{ section.id }} .cmn-bento__item:hover img { transform: scale(1.04); }
  @media screen and (max-width: 749px) {
    {%- if s.layout == 'uniform' -%}
    #shopify-section-{{ section.id }} .cmn-bento__item { width: calc((100% - {{ s.gap }}px) / 2); }
    {%- else -%}
    #shopify-section-{{ section.id }} .cmn-bento__grid { grid-template-columns: repeat(2, 1fr); }
    #shopify-section-{{ section.id }} .cmn-bento__item:nth-child(6n+5),
    #shopify-section-{{ section.id }} .cmn-bento__item:nth-child(6n+6) { grid-column: span 2; aspect-ratio: 16 / 9; }
    {%- endif -%}
  }

  /* Lightbox */
  #shopify-section-{{ section.id }} .cmn-bento__lb {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: rgba(32, 33, 27, 0.92);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  #shopify-section-{{ section.id }} .cmn-bento__lb[hidden] { display: none; }
  #shopify-section-{{ section.id }} .cmn-bento__lb-img {
    max-width: 90vw;
    max-height: 86vh;
    object-fit: contain;
    border-radius: 4px;
  }
  #shopify-section-{{ section.id }} .cmn-bento__lb-btn {
    position: absolute;
    border: none;
    background: rgba(255,255,255,0.12);
    color: #fff;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  #shopify-section-{{ section.id }} .cmn-bento__lb-btn:hover { background: rgba(255,255,255,0.25); }
  #shopify-section-{{ section.id }} .cmn-bento__lb-prev,
  #shopify-section-{{ section.id }} .cmn-bento__lb-next {
    top: 50%;
    transform: translateY(-50%);
    width: 54px;
    height: 54px;
    border-radius: 50%;
    font-size: 2rem;
    line-height: 1;
  }
  #shopify-section-{{ section.id }} .cmn-bento__lb-prev { left: 24px; }
  #shopify-section-{{ section.id }} .cmn-bento__lb-next { right: 24px; }
  #shopify-section-{{ section.id }} .cmn-bento__lb-close {
    top: 20px;
    right: 24px;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    font-size: 1.75rem;
    line-height: 1;
  }
  #shopify-section-{{ section.id }} .cmn-bento__lb-counter {
    position: absolute;
    bottom: 22px;
    left: 50%;
    transform: translateX(-50%);
    color: rgba(255,255,255,0.85);
    font-size: 0.95rem;
    letter-spacing: 0.04em;
  }
</style>

<div class="cmn-bento">
  <div class="cmn-bento__wrap" id="cmn-bento-{{ section.id }}">
    {%- if s.heading != blank -%}
      <h2 class="cmn-bento__heading">{{ s.heading }}</h2>
    {%- endif -%}
    {%- if section.blocks.size > 0 -%}
      <div class="cmn-bento__grid">
        {%- for block in section.blocks -%}
          {%- if block.settings.image != blank or block.settings.image_asset != blank -%}
            {%- if block.settings.image != blank -%}
              {%- assign full_src = block.settings.image | image_url: width: 2200 -%}
            {%- else -%}
              {%- assign full_src = block.settings.image_asset | asset_url -%}
            {%- endif -%}
            <button class="cmn-bento__item" type="button" data-index="{{ forloop.index0 }}" data-full="{{ full_src }}" aria-label="Deschide imaginea {{ forloop.index }}" {{ block.shopify_attributes }}>
              {%- if block.settings.image != blank -%}
                {{ block.settings.image | image_url: width: 1000 | image_tag: loading: 'lazy', widths: '400, 700, 1000' }}
              {%- else -%}
                <img src="{{ block.settings.image_asset | asset_url }}" loading="lazy" alt="">
              {%- endif -%}
            </button>
          {%- endif -%}
        {%- endfor -%}
      </div>

      <div class="cmn-bento__lb" hidden>
        <button class="cmn-bento__lb-btn cmn-bento__lb-close" type="button" aria-label="Închide">&times;</button>
        <button class="cmn-bento__lb-btn cmn-bento__lb-prev" type="button" aria-label="Anterior">&lsaquo;</button>
        <img class="cmn-bento__lb-img" src="" alt="">
        <button class="cmn-bento__lb-btn cmn-bento__lb-next" type="button" aria-label="Următor">&rsaquo;</button>
        <div class="cmn-bento__lb-counter"></div>
      </div>
    {%- endif -%}
  </div>
</div>

<script>
  (function () {
    var root = document.getElementById('cmn-bento-{{ section.id }}');
    if (!root) return;
    var items = Array.prototype.slice.call(root.querySelectorAll('.cmn-bento__item'));
    var lb = root.querySelector('.cmn-bento__lb');
    if (!lb || !items.length) return;
    var lbImg = lb.querySelector('.cmn-bento__lb-img');
    var counter = lb.querySelector('.cmn-bento__lb-counter');
    var sources = items.map(function (it) { return it.getAttribute('data-full'); });
    var current = 0;

    function show(i) {
      if (i < 0) i = sources.length - 1;
      if (i >= sources.length) i = 0;
      current = i;
      lbImg.src = sources[i];
      counter.textContent = (i + 1) + ' / ' + sources.length;
    }
    function open(i) { show(i); lb.hidden = false; document.body.style.overflow = 'hidden'; }
    function close() { lb.hidden = true; lbImg.src = ''; document.body.style.overflow = ''; }

    items.forEach(function (it, i) { it.addEventListener('click', function () { open(i); }); });
    lb.querySelector('.cmn-bento__lb-prev').addEventListener('click', function (e) { e.stopPropagation(); show(current - 1); });
    lb.querySelector('.cmn-bento__lb-next').addEventListener('click', function (e) { e.stopPropagation(); show(current + 1); });
    lb.querySelector('.cmn-bento__lb-close').addEventListener('click', close);
    lb.addEventListener('click', function (e) { if (e.target === lb) close(); });
    document.addEventListener('keydown', function (e) {
      if (lb.hidden) return;
      if (e.key === 'Escape') close();
      else if (e.key === 'ArrowLeft') show(current - 1);
      else if (e.key === 'ArrowRight') show(current + 1);
    });
  })();
</script>

{% schema %}
{
  "name": "Photo bento",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading" },
    { "type": "select", "id": "layout", "label": "Layout", "options": [{ "value": "bento", "label": "Bento (mixed sizes)" }, { "value": "uniform", "label": "Uniform grid" }], "default": "bento" },
    { "type": "range", "id": "columns", "label": "Columns (uniform layout)", "min": 2, "max": 8, "step": 1, "default": 4 },
    { "type": "select", "id": "uniform_ratio", "label": "Tile ratio (uniform layout)", "options": [{ "value": "1 / 1", "label": "Square" }, { "value": "4 / 3", "label": "Landscape 4:3" }, { "value": "3 / 2", "label": "Landscape 3:2" }], "default": "1 / 1" },
    { "type": "range", "id": "gap", "label": "Grid gap", "min": 0, "max": 24, "step": 2, "unit": "px", "default": 8 },
    { "type": "range", "id": "side_padding", "label": "Side padding (0 = full-bleed)", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 40 },
    { "type": "range", "id": "max_width", "label": "Max width (0 = full-bleed)", "min": 0, "max": 1600, "step": 20, "unit": "px", "default": 0 },
    { "type": "header", "content": "Appearance" },
    { "type": "color", "id": "background_color", "label": "Background", "default": "#f4f2e4" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 72 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 72 }
  ],
  "blocks": [
    {
      "type": "photo",
      "name": "Photo",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "image_asset", "label": "Image asset filename (fallback)" }
      ]
    }
  ],
  "presets": [{ "name": "Photo bento" }]
}
{% endschema %}
